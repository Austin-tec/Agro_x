# AgroTech Platform - Environment Configuration Template
# ======================================================
# 
# INSTRUCTIONS:
# 1. Copy this file and rename it to ".env" (remove the .example)
# 2. Fill in your actual values
# 3. NEVER commit the real .env file to git
# 4. Keep this .env.example in version control as a template
#
# ======================================================

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_SECRET_KEY=your-jwt-super-secret-key-change-this-in-production

# ======================================================
# EMAIL CONFIGURATION - Choose ONE option below
# ======================================================

# Option 1: GMAIL (Recommended for Testing)
# ==========================================
# Steps:
# 1. Go to myaccount.google.com/apppasswords
# 2. Login with your Gmail account
# 3. Select App: Mail, Device: Windows Computer
# 4. Google will generate a 16-character password
# 5. Copy that password below (without spaces)

MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-character-app-password
MAIL_DEFAULT_SENDER=noreply@agroxplatform.com

# ======================================================
# Option 2: SENDGRID
# ==========================================
# Uncomment these lines and comment out GMAIL settings above
# Get API key from: sendgrid.com/dynamic_mail_settings/sender_auth

# MAIL_SERVER=smtp.sendgrid.net
# MAIL_PORT=587
# MAIL_USE_TLS=True
# MAIL_USERNAME=apikey
# MAIL_PASSWORD=your-sendgrid-api-key
# MAIL_DEFAULT_SENDER=noreply@agrotechplatform.com

# ======================================================
# Option 3: MAILGUN
# ==========================================
# Uncomment these lines and comment out GMAIL settings above
# Get credentials from: mailgun.com/cp/domain_settings

# MAIL_SERVER=smtp.mailgun.org
# MAIL_PORT=587
# MAIL_USE_TLS=True
# MAIL_USERNAME=your-mailgun-smtp-username
# MAIL_PASSWORD=your-mailgun-smtp-password
# MAIL_DEFAULT_SENDER=noreply@agrotechplatform.com

# ======================================================
# Option 4: OFFICE 365
# ==========================================
# Uncomment these lines and comment out GMAIL settings above

# MAIL_SERVER=smtp.office365.com
# MAIL_PORT=587
# MAIL_USE_TLS=True
# MAIL_USERNAME=your-office-email@company.com
# MAIL_PASSWORD=your-office-password
# MAIL_DEFAULT_SENDER=your-office-email@company.com

# ======================================================
# Database Configuration (Optional - if using non-SQLite)
# ======================================================
# DATABASE_URL=postgresql://user:password@localhost:5432/agrotechdb
# Or for MySQL:
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/agrotechdb

# ======================================================
# API Configuration
# ======================================================
API_BASE_URL=http://localhost:5000
CORS_ORIGINS=*

# ======================================================
# Security Configuration
# ======================================================
JWT_EXPIRATION_HOURS=2
PASSWORD_MIN_LENGTH=8
ADMIN_SECRET_KEY=your-admin-secret-key-change-this

# ======================================================
# Application Settings
# ======================================================
APP_NAME=AgroTech Platform
APP_VERSION=1.0.0
ENVIRONMENT=development

# ======================================================
# IMPORTANT SECURITY NOTES:
# ======================================================
# 1. NEVER use the default values in production
# 2. NEVER commit the real .env file to git
# 3. Change all SECRET_KEY values before deploying
# 4. Use strong random values (at least 32 characters)
# 5. Store .env file securely on your server
# 6. Only share .env.example (without sensitive values)
# 7. For production, use a secret management service
#    (AWS Secrets Manager, Azure Key Vault, etc.)
