# Flask Configuration
FLASK_ENV=development
DEBUG=True
SECRET_KEY=your-secret-key-generate-a-strong-one

# Database
DATABASE_URL=sqlite:///agrox.db

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-generate-a-strong-one

# Email Configuration (Gmail example)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@agrox.com

# CORS
CORS_ORIGINS=http://localhost:*,localhost:*

# App Settings
ALLOW_REGISTRATION=true
IS_LAUNCHED=false
